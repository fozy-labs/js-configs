[*.{json,yml,yaml}]
indent_size = 2
",
  "gitignore": "**/node_modules
**/.idea
**/dist
**/*.tsbuildinfo
**/*.obsidian
coverage
",
  "prettierignore": "dist/
coverage/
node_modules/
*.md
",
}
`;

